		$Code_t:=$Code_t+"  // ----------------------------------------------------\r\r"
		$Code_t:=$Code_t+"C_TEXT("+$MethodName_t+" ;$1)\r"
		$Code_t:=$Code_t+"C_pointer("+$MethodName_t+" ;$0)\r"
		
		METHOD SET CODE:C1194($CompilerMethodName_t; $Code_t; *)  // code of a single method
		
		
	End if 
	
End if 
